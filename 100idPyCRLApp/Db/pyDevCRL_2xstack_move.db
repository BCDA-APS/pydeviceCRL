record(ai, "$(P)$(SYSID):$(OE):stack$(M)_dist"){
	field(VAL, "$(DIST=25)")
	}

record(sseq, "$(P)$(SYSID):$(OE):stack$(M)_move"){
	field(SELM, "Mask")
	field(DOL1, "$(P)$(SYSID):$(OE):stack$(M)_dist PP")
	field(LNK1, "$(MOT1).TWV PP")
#	field(DO2, "1")
#	field(LNK2, "$(MOT1).CNEN PP")
	field(DO2, "1")
	field(LNK2, "$(MOT1).TWF PP") 
#	field(WAIT2, "Wait")
	field(DO3, "1")
	field(LNK3, "$(MOT1).TWR PP") 
#	field(WAIT3, "Wait")
#	field(DO5, "0")
#	field(LNK5, "$(MOT1).CNEN PP")
	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_move2.PROC CA")
}

record(sseq, "$(P)$(SYSID):$(OE):stack$(M)_move2"){
	field(SELM, "Mask")
	field(SELL, "$(P)$(SYSID):$(OE):stack$(M)_move.SELN NPP") 
	field(DOL1, "$(P)$(SYSID):$(OE):stack$(M)_dist PP")
	field(LNK1, "$(MOT2).TWV PP")
#	field(DO2, "1")
#	field(LNK2, "$(MOT2).CNEN PP")
	field(DO2, "1")
	field(LNK2, "$(MOT2).TWF PP") 
#	field(WAIT2, "Wait")
	field(DO3, "1")
	field(LNK3, "$(MOT2).TWR PP") 
#	field(WAIT3, "Wait")
#	field(DO5, "0")
#	field(LNK5, "$(MOT2).CNEN PP")
	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc1.PROC CA")
}

record(scalcout, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc1"){
	field(INPA, "$(MOT1).HLS CP")
	field(INPB, "$(MOT1).LLS CP")
	field(CC, "$(INLM)")
	field(CALC, "A==B?INT(2+B):(CC=='LO'?INT(B):INT(A))")
	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc2.PROC CA")
}

record(scalcout, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc2"){
	field(INPA, "$(MOT2).HLS CP")
	field(INPB, "$(MOT2).LLS CP")
	field(CC, "$(INLM)")
	field(CALC, "A==B?INT(2+B):(CC=='LO'?INT(B):INT(A))")
	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc.PROC CA")
}

record(scalcout, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc"){
	field(INPA, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc1")
	field(INPB, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc2")
	field(CC, "$(INLM)")
	field(CALC, "A==B?INT(A):INT(3)")
}


record(calcout, "$(P)$(SYSID):$(OE):stack$(M)_DMOV"){
	field(INPA, "$(MOT1).DMOV CP")
	field(INPB, "$(MOT2).DMOV CP")
	field(CALC, "!(A and B)")
	field(OUT, "$(P)$(SYSID):$(OE):crlBusyCalc.$(MASK)")
	field(FLNK, "$(P)$(SYSID):$(OE):crlBusyCalc.PROC CA")
}

