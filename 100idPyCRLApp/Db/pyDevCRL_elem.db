record(longin, "$(P)$(SYSID):$(OE):lenses") {
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_lenses_$(OE)')")
  field(SCAN, "I/O Intr")
  field(MDEL, "-1")
#  field(FLNK, "$(P)$(SYSID):$(OE):lens_decode.PROC PP")
  field(FLNK, "$(P)$(SYSID):$(OE):lenses_comp.PROC PP")
}

#Record to determine if lenses are new
record(calcout, "$(P)$(SYSID):$(OE):lenses_comp"){
  field(INPA, "$(P)$(SYSID):$(OE):lensConfig_RBV NPP")
  field(INPB, "$(P)$(SYSID):$(OE):lenses NPP")
  field(CALC, "A=B?6:1")
  field(OUT, "$(P)$(SYSID):$(OE):lenses_seq.SELN")
  field(FLNK, "$(P)$(SYSID):$(OE):lenses_seq.PROC CA")
}

#If not new clear system busy, otherwise process lens_decode
record(sseq, "$(P)$(SYSID):$(OE):lenses_seq"){
  field(SELM, "Mask")
  field(DO1, "1")
  field(LNK1, "$(P)$(SYSID):$(OE):lens_decode.PROC PP")
  field(DO2, "0")
  field(LNK2, "$(P)$(SYSID):sysBusyCalc.$(OEL)")
  field(DO3, "1")
  field(LNK3, "$(P)$(SYSID):sysBusyCalc.PROC CA")
}

record(sseq, "$(P)$(SYSID):$(OE):setCrlBusy"){
	field(DO1, "1")
	field(LNK1, "$(P)$(SYSID):$(OE):crlBusy PP")
}

record(calcout, "$(P)$(SYSID):$(OE):crlBusyCalc") {
  field(DESC, "Each stack reports back if done moving")
  field(CALC, "A|B|C|D|E|F|G|H|I|J|K|L")
  field(OUT, "$(P)$(SYSID):$(OE):crlBusy PP")
}

record(busy, "$(P)$(SYSID):$(OE):crlBusy"){
	field(ZNAM, "Done")
	field(ONAM, "Changing")
}

record(dfanout, "$(P)$(SYSID):$(OE):crlBusyFO"){
	field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):$(OE):crlBusy CP")
	field(OUTA, "$(P)$(SYSID):sysBusyCalc.$(OEL)")
	field(FLNK, "$(P)$(SYSID):sysBusyCalc.PROC CA")
}

record(transform, "$(P)$(SYSID):$(OE):lens_decode"){
	field(INPA, "$(P)$(SYSID):$(OE):lenses PP")
	field(CLCB, "A % 2")
	field(CLCC, "(A >> 1) % 2")
	field(CLCD, "(A >> 2) % 2")
	field(CLCE, "(A >> 3) % 2")
	field(CLCF, "(A >> 4) % 2")
	field(CLCG, "(A >> 5) % 2")
	field(CLCH, "(A >> 6) % 2")
	field(CLCI, "(A >> 7) % 2")
	field(CLCJ, "(A >> 8) % 2")
	field(CLCK, "(A >> 9) % 2")
#	field(CLCL, "(A >> 10) % 2")
#	field(CLCM, "(A >> 11) % 2")
	field(FLNK, "$(P)$(SYSID):$(OE):lensSetSeq.PROC PP")
}

record(ao, "$(P)$(SYSID):$(OE):interLensDelay"){
	field(PREC, "3")
	field(FLNK, "$(P)$(SYSID):$(OE):delayFanout01.PROC PP")
}

record(dfanout, "$(P)$(SYSID):$(OE):delayFanout01"){
	field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):$(OE):interLensDelay")
	field(OUTA, "$(P)$(SYSID):$(OE):lensSetSeq.DLY0")
	field(OUTB, "$(P)$(SYSID):$(OE):lensSetSeq.DLY1")
	field(OUTC, "$(P)$(SYSID):$(OE):lensSetSeq.DLY2")
	field(OUTD, "$(P)$(SYSID):$(OE):lensSetSeq.DLY3")
	field(OUTE, "$(P)$(SYSID):$(OE):lensSetSeq.DLY4")
	field(OUTF, "$(P)$(SYSID):$(OE):lensSetSeq.DLY5")
	field(OUTG, "$(P)$(SYSID):$(OE):lensSetSeq.DLY6")
	field(OUTH, "$(P)$(SYSID):$(OE):lensSetSeq.DLY7")
	field(FLNK, "$(P)$(SYSID):$(OE):delayFanout02.PROC PP")
}

record(dfanout, "$(P)$(SYSID):$(OE):delayFanout02"){
	field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):$(OE):interLensDelay")
	field(OUTA, "$(P)$(SYSID):$(OE):lensSetSeq.DLY8")
	field(OUTB, "$(P)$(SYSID):$(OE):lensSetSeq.DLY9")
}


record(seq, "$(P)$(SYSID):$(OE):lensSetSeq"){
	field(DOL0, "$(P)$(SYSID):$(OE):lens_decode.B")
	field(DOL1, "$(P)$(SYSID):$(OE):lens_decode.C")
	field(DOL2, "$(P)$(SYSID):$(OE):lens_decode.D")
	field(DOL3, "$(P)$(SYSID):$(OE):lens_decode.E")
	field(DOL4, "$(P)$(SYSID):$(OE):lens_decode.F")
	field(DOL5, "$(P)$(SYSID):$(OE):lens_decode.G")
	field(DOL6, "$(P)$(SYSID):$(OE):lens_decode.H")
	field(DOL7, "$(P)$(SYSID):$(OE):lens_decode.I")
	field(DOL8, "$(P)$(SYSID):$(OE):lens_decode.J")
	field(DOL9, "$(P)$(SYSID):$(OE):lens_decode.K")
	field(DOA, "0")
	field(LNK0, "$(P)$(SYSID):$(OE):stack01 PP")
	field(LNK1, "$(P)$(SYSID):$(OE):stack02 PP")
	field(LNK2, "$(P)$(SYSID):$(OE):stack03 PP")
	field(LNK3, "$(P)$(SYSID):$(OE):stack04 PP")
	field(LNK4, "$(P)$(SYSID):$(OE):stack05 PP")
	field(LNK5, "$(P)$(SYSID):$(OE):stack06 PP")
	field(LNK6, "$(P)$(SYSID):$(OE):stack07 PP")
	field(LNK7, "$(P)$(SYSID):$(OE):stack08 PP")
	field(LNK8, "$(P)$(SYSID):$(OE):stack09 PP")
	field(LNK9, "$(P)$(SYSID):$(OE):stack10 PP")
	field(LNKA, "$(P)$(SYSID):$(OE):crlBusy PP")
}

record(calcout, "$(P)$(SYSID):$(OE):lens_encode"){
	field(OUT, "$(P)$(SYSID):$(OE):lensConfig_BW PP")
	field(CALC, "A+B*2+C*4+D*8+E*16+F*32+G*64+H*128+I*256+J*512")
} 

