record(calcout, "$(P)$(SYSID):$(OE):lens_RBV_encode"){
	field(OUT, "$(P)$(SYSID):$(OE):lensConfig_RBV NPP")
	field(CALC, "A+B*2+C*4+D*8+E*16+F*32+G*64+H*128+I*256+J*512")
} 

record(longout, "$(P)$(SYSID):$(OE):lensConfig_RBV") {
  field(DTYP, "pydev")
  field(OUT, "@$(OBJ).updateConfig(VAL, '$(OE)')")
}

record(calcout, "$(P)$(SYSID):$(OE):updateCalc") {
  field(DESC, "Moves complete, update RBVs")
  field(INPA, "$(P)$(SYSID):sysBusy CP")
  field(CALC, "!A")
  field(OUT, "$(P)$(SYSID):$(OE):lensConfig_RBV.PROC CA")
  field(OOPT, "Transition To Non-zero")
}

record(waveform, "$(P)$(SYSID):$(OE):configs"){
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_configs_$(OE)')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
  field(FTVL, "LONG")
  field(NELM, "$(ELEM)")
  }

record(waveform, "$(P)$(SYSID):$(OE):invF_indices"){
  field(DESC, "inverse f indices")
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_invFind_list_$(OE)')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
  field(FTVL, "DOUBLE")
  field(NELM, "$(ELEM)")
}

record(waveform, "$(P)$(SYSID):$(OE):invF"){
  field(DESC, "inverse f")
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_invF_list_$(OE)')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
  field(FTVL, "DOUBLE")
  field(NELM, "$(ELEM)")
}

record(calcout, "$(P)$(SYSID):$(OE):fSize_twk_up"){
	field(INPA, "$(P)$(SYSID):$(OE):sortedIndex_RBV")
	field(CALC, "MIN(A+1,$(ELEM)-1)")
	field(OUT, "$(P)$(SYSID):$(OE):sortedIndex PP")
}

record(calcout, "$(P)$(SYSID):$(OE):fSize_twk_dn"){
	field(INPA, "$(P)$(SYSID):$(OE):sortedIndex_RBV")
	field(CALC, "MAX(0,A-1)")
	field(OUT, "$(P)$(SYSID):$(OE):sortedIndex PP")
}

record(longout, "$(P)$(SYSID):$(OE):sortedIndex") {
  field(DTYP, "pydev")
  field(OUT, "@$(OBJ).updateIndex(VAL, '$(OE)')")
  field(FLNK, "$(P)$(SYSID):$(OE):setCrlBusy.PROC PP")
}

record(longin, "$(P)$(SYSID):$(OE):sortedIndex_RBV") {
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_index_$(OE)')")
  field(SCAN, "I/O Intr")
  field(FLNK, "$(P)$(SYSID):fPower:sortedIndex_RBV_calc.PROC CA")
}

record(scalcout, "$(P)$(SYSID):$(OE):oePosOffsetConv"){
	field(DESC, "Converting OE offset to meters")
	field(INPA, "$(OEPOS) CP")
	field(INBB, "$(OEPOS).EGU")
	field(CC, "m")
	field(DD, "mm")
	field(EE, "millimeter")
	field(FF, "millimeters")
	field(CALC, "A/(BB=CC?1:((BB=DD|BB=EE|BB=FF)?1000:1000000))")
}

record(ao, "$(P)$(SYSID):$(OE):oePositionOffset"){ 
  field(DESC, "OE position offset from local zero")
  field(PREC, "6")
  field(EGU, "m")
  field(DOL,  "$(P)$(SYSID):$(OE):oePosOffsetConv.VAL CP")
  field(OMSL, "closed_loop")
  field(DTYP, "pydev")
  field(OUT, "@$(OBJ).updateZpos(VAL, '$(OE)', 'crl')")
  field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

record(ai, "$(P)$(SYSID):$(OE):oePositionOffset_RBV"){ 
  field(DESC, "OE position offset from local zero")
  field(EGU, "m")
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_$(OE)_Offset')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
}

record(ai, "$(P)$(SYSID):$(OE):oePosition_RBV"){ 
  field(DESC, "OE position relative to source")
  field(EGU, "m")
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('new_$(OE)_pos')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
}

