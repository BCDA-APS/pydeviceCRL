record(mbbo, "$(P)$(SYSID):system1"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(DTYP, "pydev")
	field(OUT, "@$(OBJ).assignSystem('1', VAL)")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

# Pydevice 1.3.3: can't get it to handle mbbi, so using longin+dfanout --> mbbi
record(longin, "$(P)$(SYSID):system1_RBV_long"){
    field(DTYP, "pydev")
    field(INP,  "@pydev.iointr('updated_system1')")
    field(SCAN, "I/O Intr")
}

record(dfanout, "$(P)$(SYSID):system1_RBV_fo"){
    field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):system1_RBV_long CP")
	field(OUTA, "$(P)$(SYSID):system1_RBV PP")
	field(OUTB, "$(P)$(SYSID):system1_num.A")
	field(FLNK, "$(P)$(SYSID):system1_num.PROC CA")
}

record(mbbi, "$(P)$(SYSID):system1_RBV"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
}

record(calc, "$(P)$(SYSID):system1_num"){
	field(DESC, "system1 plus 1")
#	field(INPA, "$(P)$(SYSID):system1_RBV.RVAL CP")
	field(CALC, "A+1")
}

record(mbbo, "$(P)$(SYSID):system2"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(DTYP, "pydev")
	field(SDIS, "$(P)$(SYSID):singleCRLbo.VAL CP")
	field(DISV, "1")
	field(OUT, "@$(OBJ).assignSystem('2', VAL)")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

# Pydevice 1.3.3: can't get it to handle mbbi, so using longin+dfanout --> mbbi
record(longin, "$(P)$(SYSID):system2_RBV_long"){
    field(DTYP, "pydev")
    field(INP,  "@pydev.iointr('updated_system2')")
    field(SCAN, "I/O Intr")
}

record(dfanout, "$(P)$(SYSID):system2_RBV_fo"){
    field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):system2_RBV_long CP")
	field(OUTA, "$(P)$(SYSID):system2_RBV PP")
}

record(mbbi, "$(P)$(SYSID):system2_RBV"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
#    field(DTYP, "pydev")
#    field(INP,  "@pydev.iointr('updated_system2')")
#    field(SCAN, "I/O Intr")
}

record(calc, "$(P)$(SYSID):system2_num"){
	field(DESC, "system2 plus 1")
	field(INPA, "$(P)$(SYSID):system2_RBV.RVAL CP")
	field(CALC, "A+1")
}

record(calcout, "$(P)$(SYSID):coarse:fSize_twk_up"){
	field(INPA, "$(P)$(SYSID):system2_num.VAL")
	field(INPB, "$(P)$(SYSID):$(SYSA):sortedIndex_RBV")
    field(INPC, "$(P)$(SYSID):$(SYSB):sortedIndex_RBV")
    field(INPD, "$(ELEMA)")
    field(INPE, "$(ELEMB)")
  	field(CALC, "MIN((A=1?B:C)+1,(A=1?D:E)-1)")
	field(OUT, "$(P)$(SYSID):coarse:twk_dfo.VAL PP")
}

record(calcout, "$(P)$(SYSID):coarse:fSize_twk_dn"){
	field(INPA, "$(P)$(SYSID):system1_num.VAL")
	field(INPB, "$(P)$(SYSID):$(SYSA):sortedIndex_RBV")
    field(INPC, "$(P)$(SYSID):$(SYSB):sortedIndex_RBV")
	field(CALC, "A=1?MAX(0,B-1):MAX(0,C-1)")
#	field(CALC, "MAX(0,A-1)")
	field(OUT, "$(P)$(SYSID):coarse:twk_dfo.VAL PP")
}

record(dfanout, "$(P)$(SYSID):coarse:twk_dfo"){
	field(OMSL, "supervisory")
	field(SELL, "$(P)$(SYSID):system1_num.VAL")
	field(SELM, "Specified")
	field(OUTA, "$(P)$(SYSID):$(SYSA):sortedIndex PP")
    field(OUTB, "$(P)$(SYSID):$(SYSB):sortedIndex PP")
}

record(calcout, "$(P)$(SYSID):fine:fSize_twk_up"){
	field(INPA, "$(P)$(SYSID):system2_num.VAL")
	field(INPB, "$(P)$(SYSID):$(SYSA):sortedIndex_RBV")
    field(INPC, "$(P)$(SYSID):$(SYSB):sortedIndex_RBV")
    field(INPD, "$(ELEMA)")
    field(INPE, "$(ELEMB)")
  	field(CALC, "MIN((A=1?B:C)+1,(A=1?D:E)-1)")
	field(OUT, "$(P)$(SYSID):fine:twk_dfo.VAL PP")
}

record(calcout, "$(P)$(SYSID):fine:fSize_twk_dn"){
	field(INPA, "$(P)$(SYSID):system2_num.VAL")
	field(INPB, "$(P)$(SYSID):$(SYSA):sortedIndex_RBV")
    field(INPC, "$(P)$(SYSID):$(SYSB):sortedIndex_RBV")
	field(CALC, "A=1?MAX(0,B-1):MAX(0,C-1)")
	field(OUT, "$(P)$(SYSID):fine:twk_dfo.VAL PP")
}

record(dfanout, "$(P)$(SYSID):fine:twk_dfo"){
	field(OMSL, "supervisory")
	field(SELL, "$(P)$(SYSID):system2_num.VAL")
	field(SELM, "Specified")
	field(OUTA, "$(P)$(SYSID):$(SYSA):sortedIndex PP")
    field(OUTB, "$(P)$(SYSID):$(SYSB):sortedIndex PP")
}


record(longout, "$(P)$(SYSID):fPower:sortedIndex") {
  field(OUT, "$(P)$(SYSID):fPower:sortedIndex_dfo.VAL PP")
}

record(dfanout, "$(P)$(SYSID):fPower:sortedIndex_dfo"){
	field(OMSL, "supervisory")
	field(SELL, "$(P)$(SYSID):system1_num.VAL")
	field(SELM, "Specified")
	field(OUTA, "$(P)$(SYSID):$(SYSA):sortedIndex PP")
    field(OUTB, "$(P)$(SYSID):$(SYSB):sortedIndex PP")
}

record(calcout, "$(P)$(SYSID):fPower:sortedIndex_RBV_calc"){
	field(INPA, "$(P)$(SYSID):system1_num.VAL")
	field(INPB, "$(P)$(SYSID):$(SYSA):sortedIndex")
    field(INPC, "$(P)$(SYSID):$(SYSB):sortedIndex")
	field(CALC, "A=1?B:C")
	field(OUT, "$(P)$(SYSID):fPower:sortedIndex_RBV PP")
}

record(longin, "$(P)$(SYSID):fPower:sortedIndex_RBV") {
}
