record(scalcout, "$(P)$(SYSID):$(OE):slitSizeHConv"){
	field(DESC, "Converting slit size to meters")
	field(INPA, "$(SLITH) CP")
	field(INBB, "$(SLITH).EGU")
	field(CC, "m")
	field(DD, "mm")
	field(EE, "millimeter")
	field(FF, "millimeters")
	field(CALC, "A/(BB=CC?1:((BB=DD|BB=EE|BB=FF)?1000:1000000))")
}

record(ao, "$(P)$(SYSID):$(OE):slitSize_H"){
	field(EGU, "m")
    field(DOL,  "$(P)$(SYSID):$(OE):slitSizeHConv.VAL CP")
    field(OMSL, "closed_loop")
	field(DTYP, "pydev")
	field(OUT, "@$(OBJ).updateSlitSize(VAL, '$(OE)', 'hor')")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
	field(PREC, "6")
}

record(ai, "$(P)$(SYSID):$(OE):slitSize_H_RBV"){
  field(DTYP, "pydev")
  field(INP,  "@pydev.iointr('updated_slitSize_$(OE)_hor')")
  field(SCAN, "I/O Intr")
  field(PREC, "6")
  field(EGU, "m")
}

