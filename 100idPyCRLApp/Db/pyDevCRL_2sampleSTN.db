record(mbbo, "$(P)$(SYSID):sample"){
	field(ZRST, "$(SAMA)")
	field(ONST, "$(SAMB)")
	field(DTYP, "pydev")
	field(OUT, "@$(OBJ).assignSample(VAL)")
}

# Pydevice 1.3.3: can't get it to handle mbbi, so using longin+dfanout --> mbbi
record(longin, "$(P)$(SYSID):sample_RBV_long"){
    field(DTYP, "pydev")
    field(INP,  "@pydev.iointr('updated_sample')")
    field(SCAN, "I/O Intr")
}

record(dfanout, "$(P)$(SYSID):sample_RBV_fo"){
    field(OMSL, "closed_loop")
	field(DOL, "$(P)$(SYSID):sample_RBV_long CP")
	field(OUTA, "$(P)$(SYSID):sample_RBV PP")
}

record(mbbi, "$(P)$(SYSID):sample_RBV"){
	field(ZRST, "$(SAMA)")
	field(ONST, "$(SAMB)")
#	field(DTYP, "pydev")
#    field(INP,  "@pydev.iointr('updated_sample')")
#    field(SCAN, "I/O Intr")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

# F, G outputs used by Bluesky transfocator class to store sample position
record(transform, "$(P)$(SYSID):SamPosCalc"){
  field(DESC, "Sample position select calc")
  field(SCAN, "Passive")
  field(INPA, "$(P)$(SYSID):sample_RBV.RVAL CP")
  field(INPB, "$(P)$(SYSID):$(SAMA):samplePosition_RBV CP")
  field(INPC, "$(P)$(SYSID):$(SAMB):samplePosition_RBV CP")
  field(INPD, "$(P)$(SYSID):$(SAMA):samplePositionOffset_RBV CP")
  field(INPE, "$(P)$(SYSID):$(SAMB):samplePositionOffset_RBV CP")
  field(CMTF, "Sample position")
  field(CLCF, "(A==0)?B:C")
#  field(OUTF, "")
  field(CMTG, "Sample position")
  field(CLCG, "(A==0)?D:E")
#  field(OUTG, "")
  field(PREC, "4")
  field(SCAN, "Passive")
}
