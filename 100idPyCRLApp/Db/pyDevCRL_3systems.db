record(mbbo, "$(P)$(SYSID):system1"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(TWST, "$(SYSC)")
	field(DTYP, "pydev")
	field(OUT, "@$(OBJ).assignSystem('1', VAL)")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

record(mbbi, "$(P)$(SYSID):system1_RBV"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(TWST, "$(SYSC)")
    field(DTYP, "pydev")
    field(INP,  "@pydev.iointr('updated_system1')")
    field(SCAN, "I/O Intr")
    field(FLNK, "$(P)$(SYSID):resizeMinFxn.PROC CA")
}

record(calcout, "$(P)$(SYSID):resizeMinFxn"){
	field(INPA, "$(P)$(SYSID):system1_RBV_long")
	field(INPB, "$(ELEMA)")
	field(INPC, "$(ELEMB)")
	field(INPD, "$(ELEMC)")
	field(CALC, "A==0?B:(A==1?C:D)")
	field(OUT, "$(P)$(SYSID):minimizeFsize.NUSE")
}

record(mbbo, "$(P)$(SYSID):system2"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(TWST, "$(SYSC)")
	field(DTYP, "pydev")
	field(SDIS, "$(P)$(SYSID):singleCRLbo.VAL CP")
	field(DISV, "1")
	field(OUT, "@$(OBJ).assignSystem('2', VAL)")
	field(FLNK, "$(P)$(SYSID):recalc_table.PROC CA")
}

record(mbbi, "$(P)$(SYSID):system2_RBV"){
	field(ZRST, "$(SYSA)")
	field(ONST, "$(SYSB)")
	field(TWST, "$(SYSC)")
    field(DTYP, "pydev")
    field(INP,  "@pydev.iointr('updated_system2')")
	field(SDIS, "$(P)$(SYSID):singleCRLbo.VAL CP")
	field(DISV, "1")
    field(SCAN, "I/O Intr")
}
