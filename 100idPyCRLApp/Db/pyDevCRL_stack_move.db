record(ai, "$(P)$(SYSID):$(OE):stack$(M)_dist"){
	field(VAL, "$(DIST=25)")
	}

record(sseq, "$(P)$(SYSID):$(OE):stack$(M)_move"){
	field(SELM, "Mask")
	field(DOL1, "$(P)$(SYSID):$(OE):stack$(M)_dist PP")
	field(LNK1, "$(MOT).TWV PP")
#	field(DO2, "1")
#	field(LNK2, "$(MOT).CNEN PP")
	field(DO2, "1")
	field(LNK2, "$(MOT).TWF CA") 
	field(WAIT2, "Wait")
	field(DO3, "1")
	field(LNK3, "$(MOT).TWR CA") 
	field(WAIT3, "Wait")
#	field(DO5, "0")
#	field(LNK5, "$(MOT).CNEN PP")
	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc.PROC CA")
}

record(scalcout, "$(P)$(SYSID):$(OE):stack$(M)_RBV_calc"){
	field(INPA, "$(MOT).HLS CP")
	field(INPB, "$(MOT).LLS CP")
	field(CC, "$(INLM)")
	field(CALC, "A==B?INT(2+B):(CC=='LO'?INT(B):INT(A))")
#	field(OUT, "$(P)$(SYSID):$(OE):stack$(M)_RBV PP")
#	field(FLNK, "$(P)$(SYSID):$(OE):stack$(M)_matchCalc.PROC CA")
}

record(calcout, "$(P)$(SYSID):$(OE):stack$(M)_matchCalc") {
	field(INPA, "$(P)$(SYSID):$(OE):stack$(M)")
	field(INPB, "$(P)$(SYSID):$(OE):stack$(M)_RBV")
	field(INPC, "$(MOT).DMOV CP")
	field(CALC, "C==1?(A==B?1:0):1")
	field(OUT, "$(P)$(SYSID):$(OE):stack$(M)_match PP")
#	field(SDIS, "$(MOT).DMOV")
#	field(DISV, "0")
}

record(bi, "$(P)$(SYSID):$(OE):stack$(M)_match"){
	field(DESC, "Does control match RBV")
	field(ZNAM, "Mismatch")
	field(ONAM, "Match")
}

record(calcout, "$(P)$(SYSID):$(OE):stack$(M)_DMOV") {
	field(INPA, "$(MOT).DMOV CP")
	field(CALC, "!A")
	field(OUT, "$(P)$(SYSID):$(OE):crlBusyCalc.$(MASK)")
	field(FLNK, "$(P)$(SYSID):$(OE):crlBusyCalc.PROC CA")
}
